{
  "manifest_version": 3,
  "name": "Course Action Recorder",
  "description": "智能录制网课操作，支持混合策略定位系统（7层优先级）。",
  "version": "2.0.0",
  "version_name": "v2.0",
  "author": "Course Automation Through Record",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "网课录制助手"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
